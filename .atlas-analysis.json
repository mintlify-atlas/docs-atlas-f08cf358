  "keyFeatures": [
    "JWT authentication and authorization",
    "Role-based access control (user, admin, super-user)",
    "Product CRUD operations with pagination",
    "File upload and management for product images",
    "Real-time messaging via WebSockets",
    "Database seeding for initial data",
    "Swagger API documentation",
    "Docker containerization support"
  ],
  "publicApiSurface": [
    "POST /api/auth/register - User registration",
    "POST /api/auth/login - User login",
    "GET /api/auth/check-status - Check authentication status",
    "GET /api/products - List products with pagination",
    "GET /api/products/:term - Get product by ID or slug",
    "POST /api/products - Create product (auth required)",
    "PATCH /api/products/:id - Update product (admin only)",
    "DELETE /api/products/:id - Delete product (admin only)",
    "POST /api/files/product - Upload product image",
    "GET /api/files/product/:imageName - Get product image",
    "GET /api/seed - Reset and seed database",
    "WebSocket Gateway - Real-time messaging with JWT authentication"
  ]
}
